# Build artifacts. The target dir is relocated to D:\dev\reticle-target via
# CARGO_TARGET_DIR, but ignore any local target too for safety.
/target
**/target

# Media: only the final optimized assets are committed; raw frames are not.
/assets/frames/
/assets/raw/

# Optional vendored dependencies (offline builds).
/vendor/

# WASM / Trunk build output.
/dist/
/crates/web/dist/

# Coverage.
/coverage/
*.profraw
lcov.info

# mdbook render output (book is built into gh-pages, not committed to main).
/docs/book/

# Fuzzing artifacts (corpora are committed; crashes and coverage are not).
/fuzz/artifacts/
/fuzz/coverage/
/fuzz/target/

# OS / editor noise.
.DS_Store
Thumbs.db
*.swp
*~

# Local environment.
.env

# Cloudflare Wrangler local state (auth cache, DO/miniflare sim state). The
# committed relay config lives under worker/; this is machine-local runtime.
/.wrangler/
**/.wrangler/
# Worker build/runtime dirs: node_modules (npm ci restores them), the
# worker-build wasm bundle, and the worker's cargo target.
/worker/node_modules/
/worker/build/
/worker/target/

# Benchmark per-task byproducts: only the .result.json record is committed (it is
# the API), matching the v0.5.0 pattern. The per-run MCP config and captured
# transcript are local artifacts.
/benchmarks/results/**/*.mcp.json
/benchmarks/results/**/*.transcript.jsonl

# Local tooling/config and the internal build specification (not shipped).
/.claude/
/.mcp.json
/tools/
/reticle-autonomous-build-plan.md
/reticle-v6-extended-packet.md
/scratch/

# Lane RESULT.md files belong under scratch/lanes/<id>/, never the repo root.
/RESULT.md
