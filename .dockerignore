# Keep the Docker build context small and free of build artifacts and secrets.
# The workspace source, Cargo manifests, and tech/ (embedded via include_str!) are
# all that the builder needs.

# Rust build outputs (host and per-lane target dirs).
target/
**/target/

# The web bundle output and the built book.
crates/web/dist/
docs/book/
book/

# Node artifacts, if any tooling pulls them.
node_modules/
**/node_modules/

# Version control and editor metadata.
.git/
.github/
.vscode/
.idea/

# Scratch, logs, and local run outputs.
scratch/
**/*.log
lcov.info

# Never ship an env file into the build context (the key comes from run-time env).
.env
*.env
!crates/**/*.env

# Large media that the demo server does not need at build time.
assets/*.gif
