#!/bin/sh
# Reticle commit-msg hook: reject AI attribution trailers and badges. History is
# authored by the committer; a "Co-Authored-By: Claude" or "Generated with ..."
# line breaks the voice rule the same way an em-dash does. The patterns anchor on
# trailer forms (a trailer key at line start, or the "generated with/by" phrase),
# NOT on the bare words "claude" or "anthropic": ordinary prose about the
# claude-code benchmark backend or the Anthropic API must keep passing.
#
# Enable with:
#   git config core.hooksPath .githooks
msg_file="$1"
hits=$(grep -in \
    -e '^[[:space:]]*co-authored-by:.*' \
    -e '^[[:space:]]*signed-off-by:.*\(claude\|anthropic\)' \
    -e 'generated with.*claude' \
    -e 'generated by.*claude' \
    -e '^[[:space:]]*🤖' \
    "$msg_file")
if [ -n "$hits" ]; then
    echo "commit-msg: attribution trailer(s) found; write the message as the committer, no AI credits:" >&2
    echo "$hits" | sed 's/^/  /' >&2
    exit 1
fi
